{
  "name": "veliom",
  "version": "0.1.2",
  "description": "Ultra-fast, minimal frontend framework with API-agnostic design",
  "type": "module",
  "main": "./dist/veliom.js",
  "module": "./dist/veliom.js",
  "types": "./dist/veliom.d.ts",
  "exports": {
    ".": {
      "types": "./dist/veliom.d.ts",
      "import": "./dist/veliom.js",
      "require": "./dist/veliom.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm run build:types"
  },
  "keywords": [
    "frontend",
    "framework",
    "virtual-dom",
    "reactive",
    "performance",
    "lightweight",
    "components"
  ],
  "author": "DerStr1k3r",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eodstr1k3r-max/Veliom"
  },
  "bugs": {
    "url": "https://github.com/eodstr1k3r-max/Veliom/issues"
  },
  "devDependencies": {
    "@vitest/ui": "^1.0.0",
    "jsdom": "^23.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
